{
  "name": "jolly-bench",
  "version": "0.1.0",
  "description": "Load testing CLI built on jolly-coop",
  "author": "Arijit Gogoi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arijit-gogoi/jolly-bench.git"
  },
  "homepage": "https://github.com/arijit-gogoi/jolly-bench",
  "bugs": "https://github.com/arijit-gogoi/jolly-bench/issues",
  "keywords": [
    "load-testing",
    "benchmark",
    "stress-test",
    "http",
    "cli",
    "structured-concurrency",
    "jolly-coop"
  ],
  "type": "module",
  "bin": {
    "jolly-bench": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --dts",
    "pretest": "tsup src/cli.ts src/index.ts --format esm",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jolly-coop": "^0.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  }
}
